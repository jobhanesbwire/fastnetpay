# Copy to .env.production on the Ubuntu 24 VPS and set strong unique values.

APP_NAME=FASTNETPAY
APP_STAGE=Live
APP_ENV=production
APP_DISPLAY_ERRORS=0
APP_URL=https://mother.fastnetpay.co.ke
APP_BASE_DOMAIN=fastnetpay.co.ke
SUPERADMIN_HOST=mother.fastnetpay.co.ke
TENANT_WILDCARD_DOMAIN=*.fastnetpay.co.ke
APP_LOCAL_DOMAIN=
TENANT_LOCAL_TESTING=false

DB_NAME=fast_pay_net
DB_USER=fastnetpay_app
DB_PASSWORD=change_this_to_a_long_random_password
MYSQL_ROOT_PASSWORD=change_this_root_password_too

TZ=Africa/Nairobi

SECURITY_THROTTLE_ENABLED=yes
SECURITY_AI_BOT_BLOCK_ENABLED=yes
SECURITY_ROBOTS_HEADERS_ENABLED=yes
FASTNETPAY_CRON_INTERVAL=60
SESSION_NAME=FNP_PROD_SESSION

# Keep file sessions until Redis session sharing is validated in staging.
# Set SESSION_HANDLER=redis before enabling multiple app containers.
SESSION_HANDLER=files
SESSION_REDIS_DATABASE=0
SESSION_REDIS_PREFIX=fnp_prod_sess:

PAYMENT_MODE=live
SMS_MODE=live
VPN_MODE=production

# Enable only after Nginx/Cloudflare are the only public paths to the app.
SECURITY_TRUST_PROXY_HEADERS=no
