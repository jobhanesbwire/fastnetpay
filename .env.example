# FASTNETPAY environment example.
# Copy to .env only when you want to override local Docker defaults.

APP_NAME=FASTNETPAY
APP_STAGE=Dev
APP_URL=http://localhost:8088
APP_DISPLAY_ERRORS=1
APP_ENV=local
APP_BASE_DOMAIN=fastnetpay.co.ke
APP_LOCAL_DOMAIN=localhost
TENANT_LOCAL_TESTING=true

DB_HOST=fastnetpay_db
DB_PORT=3306
DB_NAME=fast_pay_net
DB_USER=fastnetpay_app
DB_PASSWORD=change_me

MYSQL_ROOT_PASSWORD=change_me

PMA_HOST=fastnetpay_db
PMA_PORT=3306
PMA_ABSOLUTE_URI=http://localhost:8089/

TZ=Africa/Nairobi

SESSION_NAME=FNP_DEV_SESSION
SESSION_HANDLER=files
SESSION_REDIS_DATABASE=0
SESSION_REDIS_PREFIX=fnp_dev_sess:

# Local development should never use live payment, SMS, VPN or router secrets.
PAYMENT_MODE=sandbox
SMS_MODE=sandbox
VPN_MODE=local
